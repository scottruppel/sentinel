# Database
DATABASE_URL=postgresql+asyncpg://sentinel:sentinel@localhost:5432/sentinel

# Nexar API (OAuth: client id + client secret — both required)
NEXAR_CLIENT_ID=
NEXAR_CLIENT_SECRET=

# Mouser Search API (optional — https://api.mouser.com)
MOUSER_API_KEY=
# Alias: MOUSER_KEY=
# MOUSER_API_URL=https://api.mouser.com/api/v1

# Digi-Key Product Information v4 (optional — OAuth2 client credentials)
# DIGIKEY_USE_SANDBOX=true
DIGIKEY_CLIENT_ID=
DIGIKEY_CLIENT_SECRET=

# SiliconExpert API (optional — stub if unavailable)
SILICONEXPERT_API_KEY=
SILICONEXPERT_API_URL=https://api.siliconexpert.com/

# Z2Data API (optional — stub if unavailable)
Z2DATA_API_KEY=

# App Settings
ENRICHMENT_CACHE_DAYS=7
ENRICHMENT_RATE_LIMIT_DELAY=0.5
RISK_DEFAULT_PROFILE=default
# Comma-separated: first preferred per field when merging provider data for scoring
ENRICHMENT_SOURCE_PRIORITY=mouser,digikey,nexar,siliconexpert,z2data,synthetic

# FRED (St. Louis Fed) — macro signals for intelligence / market_events
# FRED_API_KEY=
# Comma-separated series ids — see https://fred.stlouisfed.org
# FRED_DEFAULT_SERIES=INDPRO,PAYEMS,DTWEXBGS

# SiliconExpert: set lookup path from vendor trial docs (otherwise enrichment is skipped)
SILICONEXPERT_LOOKUP_PATH=

# Z2Data: set lookup path from vendor trial docs (otherwise enrichment is skipped)
Z2DATA_API_URL=https://api.z2data.com/
Z2DATA_LOOKUP_PATH=

# Intelligence / LLM (optional — copy to .env; never commit real keys)
# LLM_ENABLED=false
# LLM_PROVIDER=openai
# LLM_BASE_URL=http://127.0.0.1:11434/v1
# LLM_MODEL=llama3.2
# LLM_API_KEY=
# For Anthropic: LLM_PROVIDER=anthropic LLM_BASE_URL=https://api.anthropic.com LLM_MODEL=claude-haiku-4-5-20251001

# Tailscale / Agent API access
# Generate a key: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# TAILSCALE_ENABLED=false
# SENTINEL_API_KEY=
